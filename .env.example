# Example environment variables for the generative proxy
# If you run the local server (start:server), set these as needed.

# Optional: URL where the local generative proxy will run (used by CLI generator)
GENERATIVE_SERVER_URL=http://localhost:3000

# Direct Generative API endpoint (override if you need a specific model endpoint)
#GENERATIVE_API_URL=https://generativelanguage.googleapis.com/v1beta2/models/text-bison-001:generateText

# Option 1: use API key for Generative API
#GOOGLE_API_KEY=YOUR_API_KEY

# Option 2: use service account credentials (preferred for server-to-server)
# Set GOOGLE_APPLICATION_CREDENTIALS to the path of the JSON key file when running the server
# Example (Windows):
# set GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json
